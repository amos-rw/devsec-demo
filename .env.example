# .env.example — copy to .env and fill in real values before running.
# Never commit .env to version control.

# ------------------------------------------------------------
# Required
# ------------------------------------------------------------

# A long, random secret used to sign cookies and sessions.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-long-random-string

# ------------------------------------------------------------
# Development defaults (change for production)
# ------------------------------------------------------------

# Set to 'true' for development, 'false' (or omit) for production.
# Note: any non-empty value other than '1', 'true', or 'yes' is treated as False.
DJANGO_DEBUG=true

# Comma-separated list of allowed hostnames.
# Required when DJANGO_DEBUG is not true.
# Example: DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set to 'true' when the application is served over HTTPS.
# Enables: SECURE_SSL_REDIRECT, HSTS, Secure flag on session and CSRF cookies.
# Leave 'false' (or omit) for local development without HTTPS.
DJANGO_HTTPS=false
